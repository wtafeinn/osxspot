#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/feinn/osxspot/node_modules/.pnpm/astro@6.1.1_rollup@4.60.0/node_modules/astro/node_modules:/Users/feinn/osxspot/node_modules/.pnpm/astro@6.1.1_rollup@4.60.0/node_modules:/Users/feinn/osxspot/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/feinn/osxspot/node_modules/.pnpm/astro@6.1.1_rollup@4.60.0/node_modules/astro/node_modules:/Users/feinn/osxspot/node_modules/.pnpm/astro@6.1.1_rollup@4.60.0/node_modules:/Users/feinn/osxspot/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../astro/bin/astro.mjs" "$@"
else
  exec node  "$basedir/../astro/bin/astro.mjs" "$@"
fi
